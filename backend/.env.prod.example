# Copy this to .env.prod and fill in all values before deploying.
# NEVER commit .env.prod to git.

# Database (choose strong passwords)
DB_USER=psydict
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=psydict_db
DATABASE_URL=postgresql://psydict:CHANGE_ME_STRONG_PASSWORD@db:5432/psydict_db

# JWT
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING

# Claude API
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# RevenueCat
REVENUECAT_API_KEY=REPLACE_WITH_YOUR_REVENUECAT_SECRET_KEY

# Apple Sign In
APPLE_TEAM_ID=F8YFJ2J4T2
APPLE_KEY_ID=REPLACE_WITH_YOUR_KEY_ID
APPLE_PRIVATE_KEY=REPLACE_WITH_YOUR_P8_PRIVATE_KEY_CONTENTS

# APNs (Push Notifications)
APNS_KEY_ID=REPLACE_WITH_YOUR_APNS_KEY_ID
APNS_TEAM_ID=F8YFJ2J4T2
APNS_BUNDLE_ID=com.psychologydictionary.app
APNS_USE_SANDBOX=false

# DigitalOcean Spaces (for PDF/docx storage)
SPACES_KEY=REPLACE_WITH_YOUR_SPACES_ACCESS_KEY
SPACES_SECRET=REPLACE_WITH_YOUR_SPACES_SECRET_KEY
SPACES_BUCKET=psydict-documents
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# App
ENVIRONMENT=production
BASE_URL=https://api.psychologydictionary.app
CORS_ORIGINS=https://api.psychologydictionary.app
