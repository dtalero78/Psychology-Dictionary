# Database
DATABASE_URL=postgresql://psydict:psydict_dev@localhost:5432/psydict_db

# Security
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Apple Sign In
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# APNs Push Notifications
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_CERT_PATH=AuthKey_XXXXXXXX.p8
APNS_BUNDLE_ID=com.psychologydictionary.app
APNS_USE_SANDBOX=true

# RevenueCat
REVENUECAT_API_KEY=

# DigitalOcean Spaces (file storage for PDF/docx)
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=psydict-documents
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
BASE_URL=http://localhost:8000
